  "summary": {
    "focus": "本周第一条周报重写为 Tri-View Ego World + IDM 整体 proposal。",
    "progress": "Tri-View 项目卡 intro 已按两阶段 Ego World + IDM 基座模型重写；周报同步展开 object-interaction-robot 分层、IDM/control decoding、数据与实验计划。",
    "blockers": "核心瓶颈从单纯缺某个固定外部视角改为三类数据闭环：多 ego-view 共享 context、Image-Layered 分解质量、以及 generated video -> IDM action 的可执行性验证。",
    "next": "当前 TODO 收敛到 Cosmos3 测试、三视角/多 ego-view 数据替换、Gamma-World 复现、分图层/segment+inpaint/SVG 化数据集准备。"
  },
  "storyline": {
    "summary": "How real-robot infra, human demonstrations, video world models, simulators, and physical outputs form one loop.",
    "flows": [
      {
        "aria_label": "Portfolio storyline",
        "nodes": [
          {
            "role": "primary",
            "eyebrow": "Foundation",
            "title": "Real-Robot Data Infra",
            "body": "ARX, UMI, Cobot Magic, Linker hands, gloves, VIVE Tracker, and Franka + Wuji provide the hardware base for collection, calibration, and validation."
          },
          {
            "role": "primary",
            "eyebrow": "Data Models",
            "title": "Video + HOI World Modeling",
            "body": "UMI wrist views, robot-head ego videos, layered manipulation state, same-task HOI data, and rate-curve teleop research turn human operation into structured video, inferred action, and state data."
          },
          {
            "role": "outcome",
            "eyebrow": "Outputs",
            "title": "Self-Improving Sim + Physical Products",
            "body": "Agentic Real2Sim2Real-VLA evaluation, generated assets, household tasks, simulator rollouts, robot evaluation, and language / image-to-CAD design close the loop back into real-world experiments."
          }
        ],
        "connectors": [
          "->",
          "->"
        ]
      },
      {
        "eyebrow": "World-model sub-story",
      "title": "How Tri-View Ego World + IDM becomes robot data, not only generated video",
        "aria_label": "World model data sub-story",
        "nodes": [
          {
            "role": "primary",
            "eyebrow": "Wrist-view route",
            "title": "Shared-Context Ego World",
            "body": "UMI wrist cameras plus fixed or floating robot-head cameras are treated as ego views. The world model predicts synchronized, action-responsive futures over overlapping object-interaction-robot context."
          },
          {
            "role": "primary",
            "eyebrow": "Layer route",
            "title": "Image-Layered State for IDM",
            "body": "Robot layers feed pose / joint estimation and IDM supervision; object-interaction layers feed process reward and RL self-supervision; scene layers support RoboEngine-style physical augmentation and self-adaptation."
          },
          {
            "role": "outcome",
            "eyebrow": "Robot-data route",
            "title": "Executable Robot Control",
            "body": "When the arm is visible, robot pose estimation supports IDM; when it is not visible, wrist/head VO, SLAM, or visual geometry recover egomotion. The final decoder emits position, velocity, or current-loop commands."
          }
        ],
        "connectors": [
          "+",
          "->"
        ]
      }
    ]
  },
