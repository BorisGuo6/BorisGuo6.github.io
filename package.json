{
  "name": "borisguo6-github-io",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "live-server --port=8765 --host=127.0.0.1 --open=/ .",
    "dev:write-api": "node scripts/local-dashboard-write-api.mjs",
    "vercel-build": "npm run test:dashboard",
    "vercel:pull-blob": "node scripts/pull-vercel-dashboard-blob.mjs",
    "vercel:seed-blob": "node scripts/seed-vercel-dashboard-blob.mjs",
    "vercel:seed-blob:force": "node scripts/seed-vercel-dashboard-blob.mjs --force",
    "supabase:seed-sql": "node scripts/generate-dashboard-seed-sql.mjs",
    "supabase:import": "node scripts/import-dashboard-state.mjs",
    "supabase:sync": "node scripts/sync-dashboard-to-supabase.mjs",
    "supabase:sync:watch": "node scripts/sync-dashboard-to-supabase.mjs --watch --interval 3600",
    "audit:notion-reading-list": "node scripts/audit-notion-reading-list.mjs",
    "gate:isaacsim-oss": "node scripts/generate-isaacsim-open-source-gate.mjs",
    "plan:isaacsim-intake": "node scripts/generate-isaacsim-benchmark-intake-plan.mjs",
    "verify:isaacsim-catalog": "node scripts/verify-isaacsim-benchmark-catalog.mjs",
    "test:dashboard": "node test/dashboard-state-lib.test.mjs"
  },
  "devDependencies": {
    "live-server": "^1.2.2"
  },
  "dependencies": {
    "@vercel/blob": "^2.4.0"
  }
}
